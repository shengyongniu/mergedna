# Ignore checkpoints and data by default; whitelist the small reference
# artifacts that ship with the repo so the README figures and the
# inspect/results notebooks are reproducible after a fresh clone.
checkpoints/*
data/*
*.pt
*.pth
*.ckpt
!checkpoints/ecoli.pt
!data/ecoli_k12_cds.fa
